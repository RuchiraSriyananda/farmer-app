# main.kv
#:import SlideTransition kivy.uix.screenmanager.SlideTransition
#:import dp kivy.metrics.dp

ScreenManager:
    transition: SlideTransition(direction='left')

    LoginScreen:
        name: "login"

    ChatScreen:
        name: "chat"


<CustomButton@Button>:
    background_normal: ''
    background_down: ''
    background_color: (0.2, 0.7, 0.3, 1)
    color: (1, 1, 1, 1)
    font_size: '14sp'
    bold: True
    size_hint_y: None
    height: dp(50)
    border: 0, 0, 0, 0

    canvas.before:
        Color:
            rgba: self.background_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [12]


<ChatBubble>:
    text: ""
    is_sender: False
    timestamp: ""
    status: ""

    size_hint_y: None
    height: self.minimum_height
    
    BoxLayout:
        orientation: 'vertical'
        size_hint_y: None
        height: self.minimum_height
        
        BoxLayout:
            size_hint_y: None
            height: self.minimum_height
            
            Widget:
                size_hint_x: 0.15 if root.is_sender else 0.05
            
            BoxLayout:
                size_hint_x: 0.7
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                padding: dp(10), dp(8)
                spacing: dp(4)
                
                canvas.before:
                    Color:
                        rgba: (0.2, 0.8, 0.3, 1) if root.is_sender else (0.95, 0.95, 0.95, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [15, 15, 15 if root.is_sender else 5, 15 if not root.is_sender else 5]
                
                Label:
                    text: root.text
                    size_hint_y: None
                    text_size: self.width, None
                    halign: "left"
                    valign: "middle"
                    color: (1, 1, 1, 1) if root.is_sender else (0, 0, 0, 1)
                    height: self.texture_size[1]
                    
                BoxLayout:
                    size_hint_y: None
                    height: dp(18)
                    spacing: dp(5)
                    
                    Widget:
                        size_hint_x: 1
                    
                    Label:
                        text: root.timestamp
                        size_hint_x: None
                        width: self.texture_size[0]
                        font_size: "10sp"
                        color: (0.9, 0.9, 0.9, 0.9) if root.is_sender else (0.5, 0.5, 0.5, 0.8)
                        halign: "right"
                    
                    Label:
                        text: root.status
                        size_hint_x: None
                        width: self.texture_size[0] if root.status else 0
                        font_size: "10sp"
                        color: (0.9, 0.9, 0.9, 0.9) if root.is_sender else (0.5, 0.5, 0.5, 0.8)
                        halign: "right"
            
            Widget:
                size_hint_x: 0.05 if root.is_sender else 0.15
        
        Widget:
            size_hint_y: None
            height: dp(6)


<LoginScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(30)
        spacing: dp(15)

        canvas.before:
            Color:
                rgba: (0.96, 0.96, 0.96, 1)
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: 0.35
            orientation: 'vertical'
            spacing: dp(5)

            Label:
                text: "🌾"
                font_size: '60sp'
                size_hint_y: 0.6

            Label:
                text: "Farmer Connect"
                font_size: '28sp'
                bold: True
                color: (0.2, 0.6, 0.2, 1)
                size_hint_y: 0.4

            Label:
                text: "Agricultural Community Chat"
                font_size: '13sp'
                color: (0.5, 0.5, 0.5, 1)
                size_hint_y: 0.2

        VisibleTextInput:
            id: email
            hint_text: "Email Address"

        VisibleTextInput:
            id: password
            hint_text: "Password"
            password: True
            on_text_validate: root.do_login()

        CustomButton:
            id: login_btn
            text: "Login"
            on_press: root.do_login()

        Label:
            id: error_label
            text: ""
            color: (1, 0, 0, 1)
            size_hint_y: None
            height: dp(25)
            opacity: 0
            font_size: '12sp'

        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(10)

            Button:
                text: "Forgot Password?"
                background_normal: ''
                background_down: ''
                background_color: (0, 0, 0, 0)
                color: (0.4, 0.6, 0.4, 1)
                size_hint_x: 0.5
                font_size: '12sp'

            Button:
                text: "Sign Up"
                background_normal: ''
                background_down: ''
                background_color: (0, 0, 0, 0)
                color: (0.2, 0.7, 0.3, 1)
                size_hint_x: 0.5
                bold: True
                font_size: '12sp'


<ChatScreen>:
    BoxLayout:
        orientation: "vertical"

        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: [dp(15), dp(10)]
            spacing: dp(10)

            canvas.before:
                Color:
                    rgba: (0.1, 0.15, 0.1, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: "←"
                size_hint_x: 0.1
                background_normal: ''
                background_down: ''
                background_color: (0, 0, 0, 0)
                color: (1, 1, 1, 1)
                font_size: '20sp'
                on_press: root.leave_chat()

            Label:
                text: "Farmer Chat Group"
                color: (1, 1, 1, 1)
                font_size: '18sp'
                bold: True
                halign: "left"
                text_size: self.size

            BoxLayout:
                size_hint_x: 0.25
                orientation: 'vertical'

                Label:
                    id: online_status
                    text: "● Online"
                    color: (0.2, 0.9, 0.2, 1)
                    font_size: '11sp'
                    halign: "right"
                    text_size: self.size

                Label:
                    id: member_count
                    text: "24 Members"
                    color: (0.7, 0.7, 0.7, 1)
                    font_size: '10sp'
                    halign: "right"
                    text_size: self.size

        ScrollView:
            id: chat_scroll
            do_scroll_x: False
            bar_width: dp(4)
            bar_color: (0.2, 0.7, 0.3, 0.8)
            bar_inactive_color: (0.2, 0.7, 0.3, 0.4)
            scroll_y: 0

            GridLayout:
                id: chat_container
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: 0
                padding: [dp(5), dp(5), dp(5), dp(5)]

        Label:
            id: typing_status
            size_hint_y: None
            height: dp(25)
            text: ""
            opacity: 0
            color: (0.5, 0.5, 0.5, 1)
            font_size: '11sp'
            italic: True
            padding: [dp(15), 0]

        BoxLayout:
            size_hint_y: None
            height: dp(60)
            spacing: dp(8)
            padding: [dp(10), dp(8)]

            canvas.before:
                Color:
                    rgba: (1, 1, 1, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: (0.9, 0.9, 0.9, 1)
                Line:
                    rectangle: [self.x, self.y + self.height - 1, self.width, 1]

            Button:
                text: "📷"
                size_hint_x: 0.12
                background_normal: ''
                background_down: ''
                background_color: (0, 0, 0, 0)
                font_size: '20sp'
                on_press: root.send_image()

            Button:
                text: "🎤"
                size_hint_x: 0.12
                background_normal: ''
                background_down: ''
                background_color: (0, 0, 0, 0)
                font_size: '20sp'
                on_press: root.send_voice()

            VisibleTextInput:
                id: msg
                hint_text: "Type a message..."
                size_hint_x: 0.64
                on_text_validate: root.send()

            CustomButton:
                id: send_btn
                text: "Send"
                size_hint_x: 0.12
                background_color: (0.2, 0.7, 0.3, 1)
                font_size: '12sp'
                on_press: root.send()